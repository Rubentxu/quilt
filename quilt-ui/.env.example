# Quilt — Frontend Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# API key for server authentication
# The server generates one on first start and prints it to console.
# Set QUILT_API_KEY on the server side, then copy the same value here.
# VITE_QUILT_API_KEY=your-api-key-here
